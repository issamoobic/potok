# Публичный URL сайта (canonical, OG). На российском VPS обязательно подставьте свой домен.
PUBLIC_SITE_URL=https://potok.ai

# Node на VPS: порт и интерфейс (см. systemd / PM2)
# HOST=127.0.0.1
# PORT=3000

# Битрикс24 — входящий вебхук на создание лида
# Создаётся в Б24: Разработчикам → Другое → Входящий вебхук
BITRIX_WEBHOOK_URL=https://YOUR_PORTAL.bitrix24.ru/rest/1/XXXXXXXXXXXX/

# OpenRouter — ключ ТОЛЬКО на сервере, не в браузере
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# YandexGPT — резерв, работает в РФ всегда
YANDEX_FOLDER_ID=
YANDEX_API_KEY=

# Unisender — email-рассылка (РФ)
UNISENDER_API_KEY=

# Яндекс.Календарь (CalDAV) — для слотов
YANDEX_CALDAV_USER=
YANDEX_CALDAV_PASSWORD=

# Уведомления о новых лидах в Telegram (тебе)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
