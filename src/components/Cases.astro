const visibleCases = cases.slice(0, 6);
const hiddenCases = cases.slice(6);
---
<section id="cases" class="section-warm" data-logo-theme="warm">
  <div class="section-shell">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <div class="eyebrow !text-ink/70 mb-4">Кейсы</div>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tight max-w-4xl">
          Наши кейсы: реальные внедрения для крупных компаний.
        </h2>
      </div>
      <div class="grid grid-cols-3 gap-2 md:min-w-[24rem]">
        <div class="case-stat">
          <div class="case-stat__value">33</div>
          <div class="case-stat__label">кейса</div>
        </div>
        <div class="case-stat">
          <div class="case-stat__value">500k</div>
          <div class="case-stat__label">звонков/день</div>
        </div>
        <div class="case-stat">
          <div class="case-stat__value">x2-4</div>
          <div class="case-stat__label">экономика</div>
        </div>
      </div>
    </div>

    <div class="case-marquee" aria-label="Сферы бизнеса, где уже внедрены решения">
      <div class="case-marquee__track">
        {[...industries, ...industries].map((item) => (
          <span class="case-marquee__item">{item}</span>
        ))}
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" data-cases-grid>
      {visibleCases.map((c) => (
        <article class="case-card p-6 md:p-7">
          <div class="case-card-head mb-7">
            <h3 class="case-industry">{c.industry}</h3>
            <div class="case-kpi">
              <div class="case-kpi__value">{c.metric}</div>
              <div class="case-kpi__label">{c.metricLabel}</div>
            </div>
          </div>
          <div class="text-lg font-bold tracking-tight mb-3">{c.title}</div>
          <p class="text-sm leading-relaxed text-ink/74 mb-5">{c.text}</p>
          <div class="flex flex-wrap gap-2">
            {c.tags.map((tag) => <span class="case-tag">{tag}</span>)}
          </div>
        </article>
      ))}
      {hiddenCases.map((c) => (
        <article class="case-card p-6 md:p-7 hidden" data-case-extra>
          <div class="case-card-head mb-7">
            <h3 class="case-industry">{c.industry}</h3>
            <div class="case-kpi">
              <div class="case-kpi__value">{c.metric}</div>
              <div class="case-kpi__label">{c.metricLabel}</div>
            </div>
          </div>
          <div class="text-lg font-bold tracking-tight mb-3">{c.title}</div>
          <p class="text-sm leading-relaxed text-ink/74 mb-5">{c.text}</p>
          <div class="flex flex-wrap gap-2">
            {c.tags.map((tag) => <span class="case-tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 flex justify-center">
      <button class="case-more-button" type="button" data-cases-more>
        Показать ещё
      </button>
    </div>
  </div>
</section>

<script>
  const casesButton = document.querySelector('[data-cases-more]');
  const hiddenCases = document.querySelectorAll('[data-case-extra]');

  casesButton?.addEventListener('click', () => {
    const isExpanded = casesButton.getAttribute('aria-expanded') === 'true';

    hiddenCases.forEach((item) => item.classList.toggle('hidden', isExpanded));
    casesButton.setAttribute('aria-expanded', String(!isExpanded));
    casesButton.textContent = isExpanded ? 'Показать ещё' : 'Свернуть кейсы';
  });
</script>
