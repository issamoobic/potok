---
const products = [
  { n: '01', t: 'Голосовой агент', d: 'Входящие и исходящие звонки, реактивация базы, запись на услуги и первичная квалификация.' },
  { n: '02', t: 'Чат-агент', d: 'Telegram, WhatsApp и сайт. Отвечает по базе знаний, собирает контакты и передаёт сложные вопросы.' },
  { n: '03', t: 'Единый чат-центр', d: 'Все каналы в одном окне: оператор видит историю, статус заявки и подсказки ИИ.' },
  { n: '04', t: 'Массовые рассылки', d: 'Сегментированные уведомления, акции, статусы заказов и возврат клиентов в диалог.' },
  { n: '05', t: 'Виджет на сайт', d: 'Приветствует посетителя, подбирает сценарий, записывает на демо и отправляет заявку на почту.' },
  { n: '06', t: 'Оркестратор процессов', d: 'Связывает агентов, CRM, календарь и аналитику в единую систему автоматизации.' },
];
---
<section id="products" class="section-dark" data-logo-theme="dark">
  <div class="section-shell">
  <div class="eyebrow mb-4">Модули платформы</div>
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
    <h2 class="text-4xl md:text-6xl font-bold tracking-tight max-w-3xl">
      Модули платформы. Одна система продаж и поддержки.
    </h2>
    <p class="text-white/62 leading-relaxed max-w-sm">
      Каждый модуль можно запустить отдельно или собрать в единый контур автоматизации.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
    {products.map(p => (
      <div class="premium-card p-7">
        <div class="text-sm text-paper/80 mb-7">{p.n}</div>
        <div class="text-xl font-semibold mb-3">{p.t}</div>
        <div class="text-sm leading-relaxed text-white/62">{p.d}</div>
      </div>
    ))}
  </div>
  </div>
</section>
