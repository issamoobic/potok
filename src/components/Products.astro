---
const products = [
  { n: '01', t: 'Голосовой агент', d: 'Входящие и исходящие звонки. Распознаёт эмоции, паузы, намерения. Лидген, реактивация, поддержка.', dark: false },
  { n: '02', t: 'Чат-агент', d: 'WhatsApp, Telegram, сайт. Опирается на базу знаний, принимает фото и документы.', dark: false },
  { n: '03', t: 'Единый чат-центр', d: 'Все каналы в одном окне для операторов. История, передача диалога между человеком и ИИ.', dark: false },
  { n: '04', t: 'Массовые рассылки', d: 'Уведомления, акции, статусы заказов через мессенджеры, SMS, соцсети.', dark: false },
  { n: '05', t: 'Виджет на сайт', d: 'Оператор в рабочее время, ИИ — в нерабочее. Бесшовное переключение 24/7/365.', dark: false },
  { n: '06', t: 'GPT-виджет', d: 'Отвечает мгновенно. Собирает контакты. Заменяет операторов ночью. Повышает конверсию.', dark: true },
];
---
<section id="products" class="max-w-6xl mx-auto px-6 py-20 border-t border-line">
  <h2 class="text-4xl md:text-5xl font-medium tracking-tight max-w-2xl mb-12">
    Шесть решений. Один разговор с клиентом.
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
    {products.map(p => (
      <div class={`rounded-lg p-7 border ${p.dark ? 'bg-ink text-paper border-ink' : 'bg-paper border-line'} hover:scale-[1.01] transition`}>
        <div class={`text-sm mb-5 ${p.dark ? 'text-paper' : 'text-muted'}`}>{p.n}</div>
        <div class="text-lg font-medium mb-2">{p.t}</div>
        <div class={`text-sm leading-relaxed ${p.dark ? 'opacity-70' : 'text-muted'}`}>{p.d}</div>
      </div>
    ))}
  </div>
</section>
