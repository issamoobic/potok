---
const faq = [
  { q: 'С чего начинается внедрение?', a: 'С короткого демо и разбора вашей воронки: смотрим каналы, типовые обращения, CRM и точки, где ручная работа тормозит продажи.' },
  { q: 'Звучит ли голосовой агент как робот?', a: 'Нет. Современные модели синтеза речи неотличимы от человека для 90% звонящих. Можно прислушать примеры на брифе.' },
  { q: 'Что если ИИ ошибётся в разговоре?', a: 'Сложные запросы автоматически передаём оператору с историей диалога. ИИ не отвечает на то, в чём не уверен.' },
  { q: 'Можно ли интегрировать с нашей CRM?', a: 'Битрикс24, amoCRM, 1С, Retail CRM — из коробки. Любая другая — через API за 1–2 дня.' },
  { q: 'Что нужно от нас для запуска?', a: 'База знаний (можно в свободной форме), доступы к CRM/телефонии, 1–2 созвона по 30 минут. Всё остальное — на нас.' },
];
---
<section class="section-dark" data-logo-theme="dark">
  <div class="section-shell">
  <div class="eyebrow mb-4">Вопросы</div>
  <h2 class="text-4xl md:text-6xl font-bold tracking-tight max-w-3xl mb-12">
    Спрашивают часто.
  </h2>
  <div class="grid gap-3 max-w-3xl">
    {faq.map(f => (
      <details class="premium-card group px-6">
        <summary class="py-6 cursor-pointer flex justify-between items-center list-none">
          <span class="text-lg font-semibold pr-6">{f.q}</span>
          <span class="text-2xl text-paper group-open:rotate-45 transition">+</span>
        </summary>
        <div class="pb-6 text-white/62 leading-relaxed">{f.a}</div>
      </details>
    ))}
  </div>
  </div>
</section>
