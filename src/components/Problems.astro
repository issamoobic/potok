---
const problems = [
  { t: 'Менеджеры тонут в рутине', d: 'Однотипные вопросы клиентов съедают 60% времени. Дорогие сотрудники работают как FAQ-бот.' },
  { t: 'Лиды теряются ночью', d: 'Заявка пришла в 23:00 — клиент уже у конкурента к утру. Скорость ответа = деньги.' },
  { t: 'Колл-центр не масштабируется', d: 'Сезон — нужно ×3 операторов. Найм, обучение, текучка. Бюджет горит.' },
  { t: 'База клиентов «спит»', d: 'Тысячи контактов, которым давно не звонили. Прозвонить вручную — нереально.' },
];
---
<section id="problems" class="section-warm" data-logo-theme="warm">
  <div class="section-shell">
  <div class="eyebrow !text-ink/70 mb-4">Операционные потери</div>
  <h2 class="text-4xl md:text-6xl font-bold tracking-tight max-w-3xl mb-12">
    Где бизнес теряет скорость
  </h2>
  <div class="grid md:grid-cols-2 gap-4">
    {problems.map(p => (
      <div class="warm-card p-7 md:p-8">
        <div class="text-2xl font-semibold mb-3">{p.t}</div>
        <div class="text-ink/70 leading-relaxed">{p.d}</div>
      </div>
    ))}
  </div>
  </div>
</section>
