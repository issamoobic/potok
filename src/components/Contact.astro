---
---
<section id="contact" class="section-warm" data-logo-theme="warm">
  <div class="section-shell">
  <div class="grid md:grid-cols-[0.9fr_1.1fr] gap-12 items-start">
    <div>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Покажем, где ИИ сэкономит время.
      </h2>
      <p class="text-ink/72 leading-relaxed max-w-md mb-8 text-lg">
        Разберём вашу воронку, подберём агента и покажем, как встроить автоматизацию в текущие процессы.
      </p>
      <div class="text-sm text-ink/70 space-y-2">
        <div>Телефон: +7 920 355-57-87</div>
        <div>Email: <a href="mailto:kropotsystems@yandex.ru" class="underline text-ink">kropotsystems@yandex.ru</a></div>
      </div>
      <div class="contact-messenger-buttons">
        <a
          href="https://t.me/sergkropai"
          target="_blank"
          rel="noopener noreferrer"
          class="telegram-button telegram-button--contact"
        >
          <img src="/telegram-logo.png" alt="" class="telegram-button__icon" loading="lazy" />
          <span>Telegram</span>
        </a>
        <a
          href="https://max.ru/u/f9LHodD0cOJgMMvqd7pnQ7s9KaM0pJdFSTkgc0GOCz7lSq6niYlvMFi5D6s"
          target="_blank"
          rel="noopener noreferrer"
          class="max-button max-button--contact"
        >
          <img src="/max-logo.png" alt="" class="max-button__icon" loading="lazy" />
          <span>MAX</span>
        </a>
      </div>
    </div>

    <form id="lead-form" class="warm-card p-6 sm:p-8 space-y-4">
      <div>
        <label class="text-sm text-ink/68">Имя</label>
        <input name="name" required class="w-full mt-1 px-4 py-3 bg-white/12 border border-ink/20 rounded-lg focus:outline-none focus:border-ink transition" />
      </div>
      <div>
        <label class="text-sm text-ink/68">Телефон, Telegram или MAX</label>
        <input name="contact" required autocomplete="tel" inputmode="text" placeholder="+7 920 355-57-87, @username или max.ru/u/..." class="w-full mt-1 px-4 py-3 bg-white/12 border border-ink/20 rounded-lg focus:outline-none focus:border-ink transition placeholder:text-ink/45" />
      </div>
      <div>
        <label class="text-sm text-ink/68">Задача</label>
        <textarea name="task" rows="3" class="w-full mt-1 px-4 py-3 bg-white/12 border border-ink/20 rounded-lg focus:outline-none focus:border-ink transition resize-none placeholder:text-ink/45" placeholder="Например: автоматизировать первичную консультацию в чате"></textarea>
      </div>

      <label class="flex gap-3 items-start text-sm cursor-pointer">
        <input type="checkbox" name="consent_pd" required class="mt-1 flex-shrink-0" />
        <span class="text-ink/70">
          Я соглашаюсь с обработкой персональных данных в соответствии с
          <a href="/privacy" class="underline text-ink">Политикой обработки персональных данных</a>.
        </span>
      </label>

      <button type="submit" class="w-full py-3.5 cta-glow text-white rounded-lg font-semibold transition">
        Отправить заявку
      </button>
      <p class="text-xs leading-relaxed text-ink/60">
        Нажимая кнопку отправки, вы соглашаетесь с обработкой персональных данных в соответствии с
        <a href="/privacy" class="underline text-ink">Политикой обработки персональных данных</a>.
      </p>
      <div id="form-status" class="text-sm text-center text-ink/70"></div>
    </form>
  </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const validateContact = (value: string) => {
    const contact = value.trim();
    const digits = contact.replace(/\D/g, '');
    const hasPhonePrefix = /^[+\d\s().-]+$/.test(contact);
    const sameDigits = /^(\d)\1+$/.test(digits);
    const phone = hasPhonePrefix && digits.length >= 10 && digits.length <= 15 && !sameDigits;
    const telegram = /^@[a-zA-Z0-9_]{5,32}$/.test(contact) || /^(https?:\/\/)?(t\.me|telegram\.me)\/[a-zA-Z0-9_]{5,32}\/?$/i.test(contact);
    const max = /^(https?:\/\/)?max\.ru\/u\/[a-zA-Z0-9_-]{8,}(?:[/?#].*)?$/i.test(contact);

    return phone || telegram || max;
  };
  const contactFallback = `
    <div class="space-y-3">
      <div class="font-semibold text-ink">Не удалось оставить заявку, пожалуйста напишите нам удобным для вас способом.</div>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="tel:+79203555787" class="inline-flex min-h-10 items-center rounded-full border border-ink/30 px-4 text-sm font-semibold text-ink">Позвонить</a>
        <a href="https://t.me/sergkropai" target="_blank" rel="noopener noreferrer" class="inline-flex min-h-10 items-center gap-2 rounded-full border border-ink/30 px-4 text-sm font-semibold text-ink">
          <img src="/telegram-logo.png" alt="" class="h-5 w-5 rounded-md" loading="lazy" />
          Telegram
        </a>
        <a href="https://max.ru/u/f9LHodD0cOJgMMvqd7pnQ7s9KaM0pJdFSTkgc0GOCz7lSq6niYlvMFi5D6s" target="_blank" rel="noopener noreferrer" class="inline-flex min-h-10 items-center gap-2 rounded-full border border-ink/30 px-4 text-sm font-semibold text-ink">
          <img src="/max-logo.png" alt="" class="h-5 w-5 rounded-md" loading="lazy" />
          MAX
        </a>
      </div>
    </div>
  `;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Отправляем...';
    const data = Object.fromEntries(new FormData(form));
    const contact = String(data.contact || '');

    if (!validateContact(contact)) {
      status.textContent = 'Укажите корректный телефон, Telegram или MAX.';
      return;
    }

    try {
      const r = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await r.json().catch(() => ({}));

      if (r.ok) {
        status.textContent = '✓ Заявка отправлена. Мы свяжемся с вами в ближайшее время и назначим демонстрацию решений под ваш бизнес.';
        form.reset();
      } else {
        status.innerHTML = contactFallback;
      }
    } catch {
      status.innerHTML = contactFallback;
    }
  });
</script>
