---
---
<section id="contact" class="section-warm" data-logo-theme="warm">
  <div class="section-shell">
  <div class="grid md:grid-cols-[0.9fr_1.1fr] gap-12 items-start">
    <div>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Покажем, где ИИ сэкономит время.
      </h2>
      <p class="text-ink/72 leading-relaxed max-w-md mb-8 text-lg">
        Разберём вашу воронку, подберём агента и покажем, как встроить автоматизацию в текущие процессы.
      </p>
      <div class="text-sm text-ink/70 space-y-2">
        <div>Email: kropotsystems@yandex.ru</div>
        <div>Телефон: +7 920 355-57-87</div>
        <a
          href="https://t.me/kropotsystems"
          target="_blank"
          rel="noopener"
          class="contact-telegram-button"
        >
          <span>Telegram</span>
          <strong>@kropotsystems</strong>
        </a>
      </div>
    </div>

    <form id="lead-form" class="warm-card p-6 sm:p-8 space-y-4">
      <div>
        <label class="text-sm text-ink/68">Имя</label>
        <input name="name" required class="w-full mt-1 px-4 py-3 bg-white/12 border border-ink/20 rounded-lg focus:outline-none focus:border-ink transition" />
      </div>
      <div>
        <label class="text-sm text-ink/68">Телефон или email</label>
        <input name="contact" required autocomplete="email tel" inputmode="email" placeholder="+7 920 355-57-87 или name@company.ru" class="w-full mt-1 px-4 py-3 bg-white/12 border border-ink/20 rounded-lg focus:outline-none focus:border-ink transition placeholder:text-ink/45" />
      </div>
      <div>
        <label class="text-sm text-ink/68">Задача</label>
        <textarea name="task" rows="3" class="w-full mt-1 px-4 py-3 bg-white/12 border border-ink/20 rounded-lg focus:outline-none focus:border-ink transition resize-none placeholder:text-ink/45" placeholder="Например: автоматизировать первичную консультацию в чате"></textarea>
      </div>

      <label class="flex gap-3 items-start text-sm cursor-pointer">
        <input type="checkbox" name="consent_pd" required class="mt-1 flex-shrink-0" />
        <span class="text-ink/70">
          Согласен на обработку персональных данных согласно
          <a href="/privacy" class="underline text-ink">Политике конфиденциальности</a> (152-ФЗ).
        </span>
      </label>

      <label class="flex gap-3 items-start text-sm cursor-pointer">
        <input type="checkbox" name="consent_ad" class="mt-1 flex-shrink-0" />
        <span class="text-ink/70">
          Согласен получать рекламные материалы и предложения (38-ФЗ).
        </span>
      </label>

      <button type="submit" class="w-full py-3.5 cta-glow text-white rounded-lg font-semibold transition">
        Отправить заявку
      </button>
      <div id="form-status" class="text-sm text-center text-ink/70"></div>
    </form>
  </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const validateContact = (value: string) => {
    const contact = value.trim();
    const email = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i;
    const telegram = /^@?[a-zA-Z][a-zA-Z0-9_]{4,31}$/;
    const digits = contact.replace(/\D/g, '');
    const hasPhonePrefix = /^[+\d\s().-]+$/.test(contact);
    const sameDigits = /^(\d)\1+$/.test(digits);
    const phone = hasPhonePrefix && digits.length >= 10 && digits.length <= 15 && !sameDigits;

    return email.test(contact) || phone || telegram;
  };
  const contactFallback = `
    <div class="space-y-3">
      <div class="font-semibold text-ink">Не удалось оставить заявку, пожалуйста напишите нам удобным для вас способом.</div>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="https://t.me/kropotsystems" target="_blank" rel="noopener" class="inline-flex min-h-10 items-center rounded-full bg-ink px-4 text-sm font-semibold text-paper">Telegram</a>
        <a href="mailto:kropotsystems@yandex.ru" class="inline-flex min-h-10 items-center rounded-full border border-ink/30 px-4 text-sm font-semibold text-ink">Email</a>
        <a href="tel:+79203555787" class="inline-flex min-h-10 items-center rounded-full border border-ink/30 px-4 text-sm font-semibold text-ink">Позвонить</a>
      </div>
    </div>
  `;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Отправляем...';
    const data = Object.fromEntries(new FormData(form));
    const contact = String(data.contact || '');

    if (!validateContact(contact)) {
      status.textContent = 'Укажите корректный телефон, email или Telegram.';
      return;
    }

    try {
      const r = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await r.json().catch(() => ({}));

      if (r.ok) {
        status.textContent = '✓ Заявка отправлена. Свяжемся в течение часа.';
        form.reset();
      } else {
        status.innerHTML = contactFallback;
      }
    } catch {
      status.innerHTML = contactFallback;
    }
  });
</script>
