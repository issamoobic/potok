---
---
<section id="contact" class="max-w-6xl mx-auto px-6 py-20 border-t border-line">
  <div class="grid md:grid-cols-2 gap-12">
    <div>
      <div class="text-xs uppercase tracking-widest text-muted mb-3">Заявка</div>
      <h2 class="text-4xl md:text-5xl font-medium tracking-tight mb-6">
        Расскажите про задачу.
      </h2>
      <p class="text-muted leading-relaxed max-w-md mb-8">
        Свяжемся в течение часа в рабочее время. Бриф — бесплатно, без обязательств.
      </p>
      <div class="text-sm text-muted space-y-2">
        <div>📧 hello@potok.ai</div>
        <div>📞 +7 (999) 000-00-00</div>
        <div>💬 Telegram: @potok_ai</div>
      </div>
    </div>

    <form id="lead-form" class="bg-white border border-line rounded-2xl p-8 space-y-4">
      <div>
        <label class="text-sm text-muted">Имя</label>
        <input name="name" required class="w-full mt-1 px-4 py-3 bg-paper border border-line rounded-lg focus:outline-none focus:border-ink transition" />
      </div>
      <div>
        <label class="text-sm text-muted">Телефон или email</label>
        <input name="contact" required class="w-full mt-1 px-4 py-3 bg-paper border border-line rounded-lg focus:outline-none focus:border-ink transition" />
      </div>
      <div>
        <label class="text-sm text-muted">Задача</label>
        <textarea name="task" rows="3" class="w-full mt-1 px-4 py-3 bg-paper border border-line rounded-lg focus:outline-none focus:border-ink transition resize-none" placeholder="Например: автоматизировать первичную консультацию в чате"></textarea>
      </div>

      <label class="flex gap-3 items-start text-sm cursor-pointer">
        <input type="checkbox" name="consent_pd" required class="mt-1 flex-shrink-0" />
        <span class="text-muted">
          Согласен на обработку персональных данных согласно
          <a href="/privacy" class="underline text-ink">Политике конфиденциальности</a> (152-ФЗ).
        </span>
      </label>

      <label class="flex gap-3 items-start text-sm cursor-pointer">
        <input type="checkbox" name="consent_ad" class="mt-1 flex-shrink-0" />
        <span class="text-muted">
          Согласен получать рекламные материалы и предложения (38-ФЗ).
        </span>
      </label>

      <button type="submit" class="w-full py-3.5 bg-ink text-paper rounded-lg font-medium hover:opacity-90 transition">
        Отправить заявку
      </button>
      <div id="form-status" class="text-sm text-center text-muted"></div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Отправляем...';
    const data = Object.fromEntries(new FormData(form));
    try {
      const r = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (r.ok) {
        status.textContent = '✓ Заявка отправлена. Свяжемся в течение часа.';
        form.reset();
      } else {
        status.textContent = '✗ Ошибка. Напишите в Telegram: @potok_ai';
      }
    } catch {
      status.textContent = '✗ Ошибка сети. Попробуйте ещё раз.';
    }
  });
</script>
