---
const steps = [
  { n: '01', t: 'Бриф', d: 'Созваниваемся 30 минут. Понимаем задачу, считаем экономику. Никаких длинных согласований.' },
  { n: '02', t: 'Прототип', d: 'За 3–5 дней собираем рабочий MVP агента. Вы видите, как он говорит/пишет с реальными клиентами.' },
  { n: '03', t: 'Интеграция', d: 'Подключаем к CRM, телефонии, мессенджерам. Тестируем на боевом трафике 2 недели.' },
  { n: '04', t: 'Сопровождение', d: 'Дообучаем на ваших разговорах. Раз в месяц — отчёт с метриками и точками роста.' },
];
---
<section class="max-w-6xl mx-auto px-6 py-20 border-t border-line">
  <div class="text-xs uppercase tracking-widest text-muted mb-3">Процесс</div>
  <h2 class="text-4xl md:text-5xl font-medium tracking-tight max-w-2xl mb-12">
    Запуск за 2–3 недели.
  </h2>
  <div class="space-y-px bg-line">
    {steps.map(s => (
      <div class="bg-paper py-8 flex flex-col md:flex-row gap-6 md:gap-12">
        <div class="text-5xl font-medium tracking-tight text-muted md:w-32">{s.n}</div>
        <div class="md:flex-1">
          <div class="text-2xl font-medium mb-2">{s.t}</div>
          <div class="text-muted leading-relaxed max-w-xl">{s.d}</div>
        </div>
      </div>
    ))}
  </div>
</section>
