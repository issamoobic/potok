---
const steps = [
  { n: '01', t: 'Бриф', d: 'Созваниваемся 30 минут. Понимаем задачу, считаем экономику. Никаких длинных согласований.' },
  { n: '02', t: 'Прототип', d: 'За 3–5 дней собираем рабочий MVP агента. Вы видите, как он говорит/пишет с реальными клиентами.' },
  { n: '03', t: 'Интеграция', d: 'Подключаем к CRM, телефонии, мессенджерам. Тестируем на боевом трафике 2 недели.' },
  { n: '04', t: 'Сопровождение', d: 'Дообучаем на ваших разговорах. Раз в месяц — отчёт с метриками и точками роста.' },
];
---
<section class="section-dark" data-logo-theme="dark">
  <div class="section-shell">
  <div class="eyebrow mb-4">Внедрение</div>
  <h2 class="text-4xl md:text-6xl font-bold tracking-tight max-w-3xl mb-12">
    Запуск без тяжёлого IT-проекта.
  </h2>
  <div class="grid gap-4">
    {steps.map(s => (
      <div class="premium-card p-7 md:p-8 flex flex-col md:flex-row gap-6 md:gap-12">
        <div class="text-5xl font-semibold tracking-tight text-paper md:w-32">{s.n}</div>
        <div class="md:flex-1">
          <div class="text-2xl font-semibold mb-3">{s.t}</div>
          <div class="text-white/62 leading-relaxed max-w-xl">{s.d}</div>
        </div>
      </div>
    ))}
  </div>
  </div>
</section>
