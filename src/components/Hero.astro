---
const heroProducts = [
  { n: '01', t: 'Голосовой агент', d: 'Звонки, запись, реактивация базы.' },
  { n: '02', t: 'Чат-агент', d: 'Telegram, WhatsApp, сайт и поддержка.' },
  { n: '03', t: 'Email-агент', d: 'Ответы, follow-up и квалификация.' },
  { n: '04', t: 'Сайт-виджет', d: 'Демо, лиды и первичный бриф.' },
  { n: '05', t: 'Рассылки', d: 'Сегменты, возврат и уведомления.' },
  { n: '06', t: 'Чат-центр', d: 'Единое окно для ИИ и операторов.' },
];
---
<section id="hero" class="section-dark" data-logo-theme="dark">
  <div class="section-shell pt-16 md:pt-24">
    <div class="grid lg:grid-cols-[minmax(0,0.95fr)_minmax(440px,1.05fr)] gap-12 lg:gap-14 items-center">
      <div>
        <div class="eyebrow mb-5">Платформа бизнес-автоматизации</div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tightest leading-[0.98] max-w-3xl">
          Системная автоматизация бизнеса
        </h1>
        <p class="mt-7 text-lg md:text-xl leading-8 text-white/68 max-w-2xl">
          KROPOT SYSTEMS внедряет голосовых, чат- и email-агентов, связывает их с CRM, календарями и аналитикой, чтобы бизнес быстрее обрабатывал заявки и меньше зависел от ручной рутины.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-9">
          <a href="#contact" class="hero-cta hero-cta--primary cta-glow rounded-full text-center font-semibold text-white">
            Получить расчёт
          </a>
          <a href="#cases" class="hero-cta hero-cta--secondary rounded-full text-center font-semibold text-white/88 border border-white/24 hover:border-paper/60 hover:text-paper transition">
            Смотреть кейсы
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-12 max-w-2xl">
          <div class="premium-card p-5">
            <div class="text-3xl md:text-4xl font-semibold text-paper">68%</div>
            <div class="text-xs md:text-sm text-white/58 mt-2 leading-relaxed">меньше рутины в колл-центре</div>
          </div>
          <div class="premium-card p-5">
            <div class="text-3xl md:text-4xl font-semibold text-paper">3.4x</div>
            <div class="text-xs md:text-sm text-white/58 mt-2 leading-relaxed">рост конверсии в заявку</div>
          </div>
          <div class="premium-card p-5">
            <div class="text-3xl md:text-4xl font-semibold text-paper">24/7</div>
            <div class="text-xs md:text-sm text-white/58 mt-2 leading-relaxed">обработка обращений</div>
          </div>
        </div>
      </div>

      <div class="workflow-card p-6 md:p-7 flex flex-col justify-between">
        <div class="relative z-[1] flex items-center justify-between gap-4">
          <div class="text-xs uppercase tracking-[0.22em] text-white/45">Продукты</div>
          <div class="rounded-full border border-paper/30 px-4 py-2 text-xs text-paper/85">AI-платформа</div>
        </div>

        <div class="relative z-[1] grid sm:grid-cols-2 gap-3 py-7">
          {heroProducts.map((product) => (
            <div class="premium-card p-4">
              <div class="text-xs text-paper/75 mb-3">{product.n}</div>
              <div class="text-base font-semibold">{product.t}</div>
              <div class="mt-2 text-xs leading-relaxed text-white/58">{product.d}</div>
            </div>
          ))}
        </div>

        <div class="relative z-[1] rounded-2xl border border-paper/20 bg-white/[0.04] px-4 py-3 text-sm text-white/62">
          Эти же продукты ниже раскрыты подробнее.
        </div>
      </div>
    </div>
  </div>
</section>
