---
<nav id="site-nav" class="sticky top-0 z-40 border-b border-white/10 bg-[#12071c]/95 logo-on-dark">
<div class="max-w-6xl mx-auto px-5 sm:px-6 py-4 flex justify-between items-center">
  <a href="#hero" class="flex items-center gap-3 min-w-0" aria-label="KROPOT SYSTEMS">
    <span class="brand-logo-mark h-10 sm:h-12 w-[190px] sm:w-[210px]" aria-hidden="true"></span>
    <span class="sr-only">KROPOT SYSTEMS</span>
  </a>
  <div class="flex items-center gap-3 md:gap-4 text-sm text-white/72">
    <div class="hidden md:flex gap-7 items-center">
      <a href="#products" class="hover:text-paper transition">Продукты</a>
      <a href="#cases" class="hover:text-paper transition">Кейсы</a>
    </div>
    <a href="#contact" class="nav-contact-button hidden md:inline-flex">Обсудить задачу</a>
    <div class="hidden lg:flex items-center gap-2">
      <a
        href="https://t.me/sergkropai"
        target="_blank"
        rel="noopener noreferrer"
        class="telegram-button telegram-button--nav"
        aria-label="Написать в Telegram @sergkropai"
      >
        <img src="/telegram-logo.png" alt="" class="telegram-button__icon" loading="lazy" />
        <span>@sergkropai</span>
      </a>
      <a
        href="https://max.ru/u/f9LHodD0cOJgMMvqd7pnQ7s9KaM0pJdFSTkgc0GOCz7lSq6niYlvMFi5D6s"
        target="_blank"
        rel="noopener noreferrer"
        class="max-button max-button--nav"
        aria-label="Написать в MAX"
      >
        <img src="/max-logo.png" alt="" class="max-button__icon" loading="lazy" />
        <span>MAX</span>
      </a>
    </div>
  </div>
</div>
</nav>

<script is:inline>
  (() => {
    const initLogoTheme = () => {
      const nav = document.getElementById('site-nav');
      if (!nav) return;

      const sections = Array.from(document.querySelectorAll('[data-logo-theme]'));
      const setTheme = (theme) => {
        nav.classList.toggle('logo-on-warm', theme === 'warm');
        nav.classList.toggle('logo-on-dark', theme !== 'warm');
      };

      const updateTheme = () => {
        const y = Math.max(nav.getBoundingClientRect().bottom + 8, window.innerHeight * 0.5);
        const current = sections.find((section) => {
          const rect = section.getBoundingClientRect();
          return rect.top <= y && rect.bottom > y;
        });
        setTheme(current?.dataset.logoTheme || 'dark');
      };

      let isTicking = false;
      const requestThemeUpdate = () => {
        if (isTicking) return;

        isTicking = true;
        requestAnimationFrame(() => {
          updateTheme();
          isTicking = false;
        });
      };

      updateTheme();
      window.addEventListener('scroll', requestThemeUpdate, { passive: true });
      window.addEventListener('resize', requestThemeUpdate);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLogoTheme, { once: true });
    } else {
      initLogoTheme();
    }
  })();
</script>
