---
---
<nav id="site-nav" class="sticky top-0 z-40 border-b border-white/10 bg-[#12071c]/78 backdrop-blur-xl logo-on-dark">
<div class="max-w-6xl mx-auto px-5 sm:px-6 py-4 flex justify-between items-center">
  <a href="#hero" class="flex items-center gap-3 min-w-0" aria-label="KROPOT SYSTEMS">
    <span class="brand-logo-mark h-10 sm:h-12 w-[190px] sm:w-[210px]" aria-hidden="true"></span>
    <span class="sr-only">KROPOT SYSTEMS</span>
  </a>
  <div class="hidden md:flex gap-7 items-center text-sm text-white/72">
    <a href="#products" class="hover:text-paper transition">Продукты</a>
    <a href="#cases" class="hover:text-paper transition">Кейсы</a>
    <a href="#contact" class="px-4 py-2 border border-paper/45 rounded-full text-paper hover:bg-paper hover:text-ink transition">Обсудить задачу</a>
  </div>
</div>
</nav>

<script is:inline>
  (() => {
    const initLogoTheme = () => {
      const nav = document.getElementById('site-nav');
      if (!nav) return;

      const sections = Array.from(document.querySelectorAll('[data-logo-theme]'));
      const setTheme = (theme) => {
        nav.classList.toggle('logo-on-warm', theme === 'warm');
        nav.classList.toggle('logo-on-dark', theme !== 'warm');
      };

      const updateTheme = () => {
        const y = Math.max(nav.getBoundingClientRect().bottom + 8, window.innerHeight * 0.5);
        const current = sections.find((section) => {
          const rect = section.getBoundingClientRect();
          return rect.top <= y && rect.bottom > y;
        });
        setTheme(current?.dataset.logoTheme || 'dark');
      };

      let isTicking = false;
      const requestThemeUpdate = () => {
        if (isTicking) return;

        isTicking = true;
        requestAnimationFrame(() => {
          updateTheme();
          isTicking = false;
        });
      };

      updateTheme();
      window.addEventListener('scroll', requestThemeUpdate, { passive: true });
      window.addEventListener('resize', requestThemeUpdate);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLogoTheme, { once: true });
    } else {
      initLogoTheme();
    }
  })();
</script>
