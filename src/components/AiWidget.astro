---
---
<div id="ai-widget" class="fixed bottom-5 right-5 sm:bottom-6 sm:right-6 z-50">
  <button id="ai-nudge" class="hidden max-sm:!hidden absolute bottom-20 right-0 w-[340px] rounded-2xl border border-white/14 bg-[#150823]/95 p-5 text-left text-sm text-white shadow-2xl backdrop-blur-xl hover:border-paper/45 transition">
    <div class="text-lg font-semibold leading-tight text-paper">Показать демо ИИ-агентов?</div>
    <div class="mt-2 text-sm leading-relaxed text-white/68">
      Подскажем, где ИИ сэкономит время, и покажем сценарий под ваш бизнес.
    </div>
    <div class="mt-4 inline-flex rounded-full bg-paper px-4 py-2 text-xs font-semibold text-ink">
      Подобрать решение
    </div>
  </button>
  <button id="ai-toggle" class="widget-pulse w-[4.75rem] h-[4.75rem] sm:w-20 sm:h-20 rounded-full text-white shadow-2xl hover:scale-[1.04] transition flex items-center justify-center border border-paper/35" aria-label="Открыть ИИ-ассистента">
    <span class="ai-trigger-core" aria-hidden="true">
      <span class="ai-trigger-orbit"></span>
      <span class="ai-trigger-spark"></span>
    </span>
  </button>

  <div id="ai-panel" class="hidden absolute bottom-20 right-0 w-[min(360px,calc(100vw-2.5rem))] bg-[#150823]/95 text-white border border-white/14 rounded-2xl shadow-2xl overflow-hidden flex flex-col backdrop-blur-xl" style="max-height: calc(100vh - 8rem);">
    <div class="px-5 py-4 border-b border-white/10 flex justify-between items-start gap-4">
      <div>
        <div class="font-semibold leading-tight text-paper">Покажем, где ИИ сэкономит время</div>
      </div>
      <button id="ai-close" class="text-white/50 hover:text-paper text-xl leading-none" aria-label="Закрыть">×</button>
    </div>

    <div id="widget-steps" class="p-5 space-y-4 overflow-y-auto">
      <div id="step-start" class="space-y-4">
        <p class="text-sm leading-relaxed">
          Привет! С какой задачей пришли? Выберите направление — покажем, как встроить ИИ в бизнес и повысить эффективность.
        </p>
        <div class="grid grid-cols-2 gap-2">
          <button class="choice-btn" data-product="voice">Звонки</button>
          <button class="choice-btn" data-product="chat">Чаты</button>
          <button class="choice-btn" data-product="widget">Сайт-виджет</button>
          <button class="choice-btn" data-product="broadcasts">Рассылки</button>
          <button class="choice-btn" data-product="center">Чат-центр</button>
          <button class="choice-btn" data-product="demo">Демо</button>
        </div>
      </div>

      <div id="step-goal" class="hidden space-y-4">
        <p class="text-sm leading-relaxed">
          Что важнее улучшить в первую очередь?
        </p>
        <div class="grid grid-cols-1 gap-2">
          <button class="goal-btn" data-goal="leads">Больше заявок</button>
          <button class="goal-btn" data-goal="routine">Меньше рутины</button>
          <button class="goal-btn" data-goal="support">Поддержка 24/7</button>
          <button class="goal-btn" data-goal="reactivation">Вернуть старых клиентов</button>
        </div>
      </div>

      <form id="widget-form" class="hidden space-y-3">
        <p class="text-sm leading-relaxed">
          Отлично. Расскажите, что хотите автоматизировать или посмотреть в работе, и оставьте контакт.
        </p>
        <input name="name" required placeholder="Имя" class="widget-input" />
        <input name="contact" required autocomplete="email tel" inputmode="email" placeholder="Телефон, email или Telegram" class="widget-input" />
        <textarea name="comment" rows="3" placeholder="Что нужно автоматизировать или показать на демо" class="widget-input resize-none"></textarea>
        <label class="widget-consent">
          <input type="checkbox" name="consent_pd" required />
          <span>
            Согласен на обработку персональных данных
            <a href="/privacy">по политике</a>.
          </span>
        </label>
        <label class="widget-consent">
          <input type="checkbox" name="consent_ad" />
          <span>Согласен получать предложения и материалы.</span>
        </label>
        <button class="w-full bg-paper text-ink rounded-lg px-4 py-3 text-sm font-semibold hover:opacity-90 transition">
          Отправить заявку
        </button>
        <div id="widget-status" class="min-h-5 text-xs opacity-80"></div>
      </form>

      <div id="widget-success" class="hidden space-y-3">
        <div id="widget-success-title" class="text-lg font-semibold">Заявка отправлена</div>
        <p id="widget-success-text" class="text-sm leading-relaxed opacity-90">
          Спасибо! Мы свяжемся с вами в ближайшее время и назначим демонстрацию решений под ваш бизнес.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .choice-btn,
  .goal-btn {
    border: 1px solid rgba(255, 106, 0, 0.34);
    border-radius: 10px;
    padding: 10px 12px;
    color: #FF6A00;
    font-size: 14px;
    line-height: 1.2;
    text-align: left;
    background: rgba(255, 255, 255, 0.035);
    transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .choice-btn:hover,
  .goal-btn:hover {
    background: rgba(255, 106, 0, 0.16);
    border-color: rgba(255, 106, 0, 0.68);
    color: #FF8A2A;
  }

  .widget-input {
    width: 100%;
    border: 1px solid rgba(255, 106, 0, 0.36);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.055);
    color: #fff4eb;
    padding: 11px 12px;
    font-size: 14px;
    outline: none;
  }

  .widget-input::placeholder {
    color: rgba(255, 244, 235, 0.48);
  }

  .widget-input:focus {
    border-color: #FF6A00;
    box-shadow: 0 0 0 2px rgba(255, 106, 0, 0.25);
  }

  .widget-consent {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    color: rgba(255, 244, 235, 0.72);
    font-size: 0.72rem;
    line-height: 1.35;
  }

  .widget-consent input {
    flex: 0 0 auto;
    margin-top: 0.12rem;
  }

  .widget-consent a {
    color: #ff8a2a;
    text-decoration: underline;
  }

</style>

<script is:inline>
  (() => {
    const toggle = document.getElementById('ai-toggle');
    const panel = document.getElementById('ai-panel');
    const nudge = document.getElementById('ai-nudge');
    const closeBtn = document.getElementById('ai-close');
    const startStep = document.getElementById('step-start');
    const goalStep = document.getElementById('step-goal');
    const widgetForm = document.getElementById('widget-form');
    const successStep = document.getElementById('widget-success');
    const successTitle = document.getElementById('widget-success-title');
    const successText = document.getElementById('widget-success-text');
    const status = document.getElementById('widget-status');
    const validateContact = (value) => {
      const contact = value.trim();
      const email = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i;
      const telegram = /^@?[a-zA-Z][a-zA-Z0-9_]{4,31}$/;
      const digits = contact.replace(/\D/g, '');
      const hasPhonePrefix = /^[+\d\s().-]+$/.test(contact);
      const sameDigits = /^(\d)\1+$/.test(digits);
      const phone = hasPhonePrefix && digits.length >= 10 && digits.length <= 15 && !sameDigits;

      return email.test(contact) || phone || telegram;
    };
    const contactFallback = `
      <div class="space-y-3">
        <div class="text-xs leading-relaxed text-white/78">Не удалось оставить заявку, пожалуйста напишите нам удобным для вас способом.</div>
        <div class="grid grid-cols-1 gap-2">
          <a href="mailto:kropotsystems@yandex.ru" class="widget-contact-link">Email</a>
          <a href="tel:+79203555787" class="widget-contact-link">Позвонить</a>
          <a href="https://max.ru/u/f9LHodD0cOJgMMvqd7pnQ7s9KaM0pJdFSTkgc0GOCz7lSq6niYlvMFi5D6s" target="_blank" rel="noopener noreferrer" class="widget-max-link">
            <img src="/max-logo.png" alt="" class="widget-max-link__icon" loading="lazy" />
            <span>Написать в MAX</span>
          </a>
        </div>
      </div>
    `;

    if (!toggle || !panel || !nudge || !closeBtn || !startStep || !goalStep || !widgetForm || !successStep || !successTitle || !successText || !status) {
      return;
    }

    const state = {
      product: 'demo',
      goal: 'integration',
    };

    function showOnly(step) {
      [startStep, goalStep, widgetForm, successStep].forEach((el) => el.classList.add('hidden'));
      step.classList.remove('hidden');
    }

    function showContactFallback(target) {
      target.innerHTML = contactFallback;
    }

    function openPanel() {
      nudge.classList.add('hidden');
      panel.classList.remove('hidden');
    }

    toggle.addEventListener('click', () => {
      nudge.classList.add('hidden');
      panel.classList.toggle('hidden');
    });
    nudge.addEventListener('click', openPanel);

    closeBtn.addEventListener('click', () => panel.classList.add('hidden'));

    document.querySelectorAll('.choice-btn').forEach((button) => {
      button.addEventListener('click', () => {
        state.product = button.dataset.product || 'demo';
        showOnly(state.product === 'demo' ? widgetForm : goalStep);
      });
    });

    document.querySelectorAll('.goal-btn').forEach((button) => {
      button.addEventListener('click', () => {
        state.goal = button.dataset.goal || 'integration';
        showOnly(widgetForm);
      });
    });

    widgetForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.textContent = 'Отправляем...';
      const formData = Object.fromEntries(new FormData(widgetForm));

      if (!validateContact(String(formData.contact || ''))) {
        status.textContent = 'Укажите корректный телефон, email или Telegram.';
        return;
      }

      if (!formData.consent_pd) {
        status.textContent = 'Подтвердите согласие на обработку данных.';
        return;
      }

      try {
        const response = await fetch('/api/widget-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...formData, ...state }),
        });

        if (!response.ok) {
          showContactFallback(status);
          return;
        }

        successTitle.textContent = 'Заявка отправлена';
        successText.textContent = 'Спасибо! Мы свяжемся с вами в ближайшее время и назначим демонстрацию решений под ваш бизнес.';
        widgetForm.reset();
        showOnly(successStep);
      } catch {
        showContactFallback(status);
      }
    });

    window.setTimeout(() => {
      if (panel.classList.contains('hidden')) {
        nudge.classList.remove('hidden');
      }
    }, 5000);
  })();
</script>
